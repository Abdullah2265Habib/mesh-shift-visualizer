{
  "version": 2,
  "builds": [
    { "src": "wsgi.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "wsgi.py" }
  ]
}